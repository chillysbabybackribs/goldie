# Goldie — local dev secrets. Copy this file to `.env` and fill in real keys.
# The .env file is gitignored and is loaded ONLY into the Electron main
# process — keys never reach the renderer or any embedded web page.

# Anthropic (Claude / Haiku 4.5 planner)
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini (Gemini 3.x Flash planner)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
